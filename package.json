{
  "name": "@lastro-co/design-system",
  "version": "1.0.8",
  "description": "Lastro Design System — UI components, icons, and design tokens",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/lastro-co/design-system.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./icons": {
      "import": {
        "types": "./dist/icons.d.ts",
        "default": "./dist/icons.js"
      },
      "require": {
        "types": "./dist/icons.d.cts",
        "default": "./dist/icons.cjs"
      }
    },
    "./styles.css": "./dist/styles.css",
    "./tailwind.config": "./tailwind.config.ts"
  },
  "files": [
    "dist",
    "tailwind.config.ts",
    "src/styles"
  ],
  "scripts": {
    "build": "tsup && node scripts/build-css.mjs && node scripts/add-use-client.mjs",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "prepublishOnly": "pnpm run build",
    "test": "TZ=UTC jest",
    "test:watch": "TZ=UTC jest --watch",
    "test:coverage": "jest --coverage",
    "shadcn:add": "node scripts/add-shadcn-component.cjs",
    "shadcn:organize": "node scripts/organize-shadcn.cjs",
    "test:generate-output": "TZ=UTC jest --json --outputFile=.jest-test-results.json || true",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "pnpm run test:generate-output && storybook build"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0",
    "tailwindcss": ">=4.0.0",
    "maplibre-gl": ">=5.18.0",
    "react-hook-form": "*",
    "zod": "*",
    "@hookform/resolvers": "*"
  },
  "peerDependenciesMeta": {
    "maplibre-gl": {
      "optional": true
    },
    "react-hook-form": {
      "optional": true
    },
    "zod": {
      "optional": true
    },
    "@hookform/resolvers": {
      "optional": true
    }
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "radix-ui": "^1.4.3",
    "react-day-picker": "^9.13.2",
    "react-dropzone": "^14.4.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "vaul": "^1.1.2",
    "wavesurfer.js": "^7.12.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.6",
    "@hookform/resolvers": "^5.2.2",
    "@mdx-js/rollup": "^3.1.1",
    "@storybook/addon-docs": "^10.2.17",
    "@storybook/addon-jest": "10.0.0-beta.12",
    "@storybook/manager-api": "^8.6.14",
    "@storybook/react-vite": "^10.2.17",
    "@storybook/theming": "^8.6.14",
    "@swc/core": "^1.15.18",
    "@swc/jest": "^0.2.39",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "postcss": "^8.5.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "storybook": "^10.2.17",
    "tailwindcss": "^4.1.18",
    "tsup": "^8.5.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "ultracite": "^5.6.4",
    "vite": "^7.3.1",
    "zod": "^4.3.6"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "esbuild",
      "unrs-resolver"
    ]
  }
}
